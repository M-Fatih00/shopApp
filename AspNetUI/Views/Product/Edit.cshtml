@model AspNetUI.DTOs.Product.UpdateProductDTO

@{
    Layout = "_AdminLayout";
}

<form method="post" enctype="multipart/form-data">
    <div class="row">

        <!-- SOL TARAF -->
        <div class="col-md-9">
            <div class="card shadow">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <h5 class="card-title">Ürün Güncelle</h5>
                    <a href="urun.html" class="btn btn-sm btn-primary">
                        <i class="fa-solid fa-list"></i>
                    </a>
                </div>

                <div class="card-body">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <input asp-for="Id" type="hidden" />
                    <input asp-for="ResimAdi" type="hidden" />

                    <div class="row mb-3">
                        <label asp-for="UrunAdi" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="UrunAdi" class="form-control" />
                            <span asp-validation-for="UrunAdi" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Aciklama" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <textarea asp-for="Aciklama" rows="3" class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Fiyat" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Fiyat" value="@Model.Fiyat.ToString("F0")" class="form-control" />
                            <span asp-validation-for="Fiyat" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Aktif" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Aktif" class="form-check-input" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Anasayfa" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Anasayfa" class="form-check-input" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="KategoriId" class="col-sm-2 col-form-label">Kategori</label>
                        <div class="col-sm-10">
                            <select asp-for="KategoriId" asp-items="ViewBag.Kategoriler" class="form-select">
                                <option value="">Seçiniz</option>
                            </select>
                            <span asp-validation-for="KategoriId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- SAĞ TARAF (RESİM) -->
        <div class="col-md-3">
            <div class="card shadow">
                <div class="card-body text-center">

                    <img src="@(ViewBag.ApiUrl)images/@Model.ResimAdi" class="img-thumbnail mb-2" alt="@Model.UrunAdi" style="max-width: 200px;">
            
                    @* Yeni resim seçmek için IFormFile olan Resim kullanılır *@
                    <input asp-for="Resim" type="file" class="form-control mt-3">
                        <span asp-validation-for="Resim" class="text-danger"></span>
                    </div>
                </div>
            </div>

        </div>
    </form>

    @section Scripts {
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }