@using AspNetUI.DTOs.Product
@model AspNetUI.DTOs.Product.ProductDetailDTO

@section Bar {
    @await Component.InvokeAsync("Navbar")
}


<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="gallery-wrap">
    <div class="img-big-wrap img-thumbnail">
        @* Büyük resim (lightbox için) *@
        <a href="@(ViewBag.ApiUrl)images/@Model.ResimAdi" data-type="image" data-fslightbox>
            <img src="@(ViewBag.ApiUrl)images/@Model.ResimAdi" alt="@Model.UrunAdi">
        </a>
    </div>
    
    <div class="thumbs-wrap">
        <a href="@(ViewBag.ApiUrl)images/@Model.ResimAdi" data-type="image" data-fslightbox>
            <img src="@(ViewBag.ApiUrl)images/@Model.ResimAdi" height="60" alt="">
        </a>
    </div>
</div>
            </div>
            <div class="col-lg-7">
                <article>
                    <h4 class="title text-dark">@Model.UrunAdi</h4>
                    <div class="rating-wrap">
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star"></span>
                    </div>
                    <p class="text-success">Stokta</p>
                    <div class="mb-3"><b class="price h5">@Model.Fiyat.ToString("0,0") ₺</b></div>
                    <div class="product-description mb-3">@Model.Aciklama</div>

                    <div class="buttons">
                        <form action="/Cart/AddToCart" method="post" class="me-1 d-inline">
                            <input type="hidden" name="urunId" value="@Model.Id">
                            <button type="submit" href="#" class="btn btn-warning">
                                <i class="fa fa-shopping-basket"></i> Sepete Ekle
                            </button>
                        </form>
                        <a href="#" class="btn btn-light">
                            <i class="fa-regular fa-heart basket me-1"></i> Listeye Ekle
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

@{
    var urunler = ViewData["BenzerUrunler"] as List<ListProductsDTO> ?? new();
}

@if (urunler.Any())
{
    <section class="mt-3">
        <div class="container">
            <h4 class="mb-3">Benzer Ürünler</h4>
            <div class="row gy-3">
                @foreach (var item in urunler)
                {
                    <div class="col-lg-3 col-sm-6 col-12">
                        <div class="card shadow">
                            <div class="img-wrap">
                                <img src="@(ViewBag.ApiUrl)images/@item.Resim" alt="@item.UrunAdi" class="card-img-top">
                            </div>
                            <div class="info-wrap">
                                <a asp-action="Details" asp-route-id="@item.Id" class="title">@item.UrunAdi</a>
                                <div class="price-wrap">
                                    <span class="price">@item.Fiyat.ToString("0,0") ₺</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}