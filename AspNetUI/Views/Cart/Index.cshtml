@model AspNetUI.DTOs.Cart.CartDTO

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#">Anasayfa</a>
                    </li>
                    <li class="breadcrumb-item">
                        Alışveriş Sepeti
                    </li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-3">
    <div class="container">
        @if (Model.CartItems.Count == 0)
        {
            <div class="alert alert-warning">
                Sepette bir ürün yok.
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-lg-7">
                    <ul class="list-group">
                        @foreach (var item in Model.CartItems)
                        {
                            <li class="py-3 mb-2 border-top list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-7">
                                        <div class="d-flex align-items-center">
                                            <img src="@(ViewBag.ApiUrl ?? "http://localhost:5237/")images/@item.Resim"
                                                 style="width: 100px;" alt="@item.UrunAdi">
                                            <div class="ms-3">
                                                <a class="text-decoration-none" asp-controller="Product" asp-action="Details"
                                                   asp-route-id="@item.UrunId">
                                                    <h6 class="mb-0">@item.UrunAdi</h6>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-2">
                                        <div class="d-flex align-items-center">
                                            <form action="/Cart/RemoveItem" method="post" class="d-inline">
                                                <input type="hidden" name="urunId" value="@item.UrunId">
                                                <input type="hidden" name="miktar" value="1">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" @(item.Miktar <=
                                                                                                    1 ? "disabled" : "")>
                                                    <i class="fa-solid fa-minus"></i>
                                                </button>
                                            </form>
                                            <span class="mx-2 fw-bold">@item.Miktar</span>
                                            <form action="/Cart/AddToCart" method="post" class="d-inline">
                                                <input type="hidden" name="urunId" value="@item.UrunId">
                                                <input type="hidden" name="miktar" value="1">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                    <i class="fa-solid fa-plus"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                    <div class="col-2 text-center">
                                        <span class="fw-bold">@item.Fiyat.ToString("0,0") ₺</span>
                                    </div>
                                    <div class="col-1">
                                        <form action="/Cart/RemoveItem" method="post">
                                            <input type="hidden" name="urunId" value="@item.UrunId">
                                            <input type="hidden" name="miktar" value="1">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <div class="col-lg-5">
                    <div class="card">
                        <div class="p-3 card-body">
                            <h2 class="h5 mb-4">Sipariş Özeti</h2>
                            <div class="card mb-2">
                                <div class="list-group list-group-flush">
                                    <div class="d-flex justify-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Sipariş Toplamı</div>
                                        </div>
                                        <span>@Model.AraToplam.ToString("0,0") ₺</span>

                                    </div>
                                    <div class="d-flex justify-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Kargo Ücreti</div>
                                        </div>
                                        <span>Ücretsiz</span>
                                    </div>
                                    <div class="d-flex justify-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Vergi (%20)</div>
                                        </div>
                                        <span>@((Model.AraToplam * 0.2m).ToString("0,0")) ₺</span>
                                    </div>
                                    <div class="d-flex justify-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Toplam</div>
                                        </div>
                                        <span>@Model.Toplam.ToString("0,0") ₺</span>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg">
                                    Alışverişe Devam
                                </a>
                                <a asp-controller="Order" asp-action="Checkout" class="btn btn-danger btn-lg">
                                    Siparişi Tamamla
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>