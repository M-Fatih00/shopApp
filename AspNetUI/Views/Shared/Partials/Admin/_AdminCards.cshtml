@using AspNetUI.DTOs.Order
@model List<OrderDTO>

@{
    var now = DateTime.Now;

    var thisMonthOrders = Model
        .Where(o => o.SiparisTarihi.Month == now.Month && o.SiparisTarihi.Year == now.Year)
        .ToList();

    var thisMonthSales = thisMonthOrders.Sum(o => o.ToplamFiyat);
    var totalSales = Model.Sum(o => o.ToplamFiyat);

    // Bu ay satılan ürün adedi
    var soldProductCount = Model
        .SelectMany(o => o.OrderItems)
        .Sum(oi => oi.Miktar);
    
}

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-primary text-uppercase mb-1">Bu ayki ciro</div>
                        <div class="h5 mb-0 fw-bold">@thisMonthSales.ToString("N0") ₺</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toplam Ciro -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-success text-uppercase mb-1">Toplam Ciro</div>
                        <div class="h5 mb-0 fw-bold">@totalSales.ToString("N0") ₺</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-primary text-uppercase mb-1">Sipariş</div>
                        <div class="h5 mb-0 fw-bold">@Model.Count</div>
                    </div>
                    <div class="col-auto">
                        <i class="fa-solid fa-truck fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-primary text-uppercase mb-1">Satılan Ürün</div>
                        <div class="h5 mb-0 fw-bold">@soldProductCount</div>
                    </div>
                    <div class="col-auto">
                        <i class="fa-solid fa-list fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col">
                        <div class="fw-bold text-primary text-uppercase mb-1">Mesaj</div>
                        <div class="h5 mb-0 fw-bold">432</div>
                    </div>
                    <div class="col-auto">
                        <i class="fa-solid fa-message fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div> *@
</div>