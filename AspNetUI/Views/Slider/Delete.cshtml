@model AspNetUI.DTOs.Slider.ListSlidersDTO


@{
    Layout = "_AdminLayout";
}


<div class="row">
    <div class="col">
        <div class="card">
            
            <img src="~/img/@Model.Resim" class="card-img-top" alt="">

            <div class="card-body text-center">
                <p>
                    @Model.Baslik isimli slider'ı silmek istiyor musunuz?
                </p>
                
                <form asp-controller="Slider" asp-action="DeleteConfirm" method="post">
                    <input type="hidden" name="id" value="@Model.Id">
                    <button type="submit" class="btn btn-danger">Sil</button>
                    <a class="btn btn-primary" asp-controller="Slider" asp-action="Index">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>